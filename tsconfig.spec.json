{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./out-tsc/spec",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@angular/core/testing": ["src/typings.d.ts"]
    },
    "types": [
      "jasmine"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "files": [
    "src/typings.d.ts"
  ]
}